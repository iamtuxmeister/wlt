{erl_opts, [debug_info, {i, "_build/default/lib"}]}.

{deps, [
    {cowboy,  "2.10.0"},
    {erlydtl, "0.14.0"},
    {esqlite, "0.8.0"},
    %% {epgsql,   "4.7.1"},   %% PostgreSQL — uncomment to activate
    %% {poolboy,  "1.5.2"},   %% connection pooling for pg
    {jsone,   "1.8.1"}
]}.

{profiles, [
    {dev, [
        {deps, [{fs, "3.4.0"}]},
        {shell, [
            {config, "config/sys.config"},
            {apps,   [fs, wlt]}
        ]}
    ]}
]}.

{shell, [
    {config, "config/sys.config"},
    {apps,   [wlt]}
]}.

{plugins, [rebar3_erlydtl_plugin]}.

{provider_hooks, [
    {pre, [{compile, {erlydtl, compile}}]}
]}.

{erlydtl_opts, [
    {source_ext, ".html"},
    {module_ext, "_dtl"},
    {doc_root,   "priv/templates"},
    {recursive,  true},
    {compiler_options, [debug_info, return]}
]}.

{relx, [
    {release, {wlt, "0.1.0"}, [wlt, sasl]},
    {mode, dev},
    {sys_config_src, "config/sys.config.src"},
    {vm_args,    "config/vm.args"},
    {include_erts, false},
    {extended_start_script, true}
]}.
